{
  "name": "ny-sheriff-summer-camp-scheduler",
  "productName": "ny-sheriff-summer-camp-scheduler",
  "version": "1.0.0",
  "description": "Schedule attendees to sports activity time-slots",
  "main": ".webpack/main",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "test:e2e": "cross-env TEST_RUN=true NODE_ENV=test electron-forge package && cross-env TEST_RUN=true NODE_ENV=test playwright test && nyc report",
    "coverage:report": "nyc report",
    "test:vitest": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test": "run-s test:vitest test:e2e"
  },
  "keywords": [],
  "author": {
    "name": "Darren Haynes",
    "email": "darren.haynes.mr@outlook.com"
  },
  "license": "SEE LICENSE IN LICENSE",
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.1",
    "@babel/preset-react": "^8.0.1",
    "@babel/preset-typescript": "^8.0.1",
    "@electron-forge/cli": "^7.10.2",
    "@electron-forge/maker-deb": "^7.10.2",
    "@electron-forge/maker-dmg": "^7.10.2",
    "@electron-forge/maker-rpm": "^7.10.2",
    "@electron-forge/maker-squirrel": "^7.10.2",
    "@electron-forge/maker-wix": "^7.10.2",
    "@electron-forge/maker-zip": "^7.10.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.10.2",
    "@electron-forge/plugin-fuses": "^7.10.2",
    "@electron-forge/plugin-webpack": "^7.10.2",
    "@electron/fuses": "^1.8.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vercel/webpack-asset-relocator-loader": "^1.7.3",
    "@vitest/coverage-v8": "^4.1.9",
    "babel-loader": "^10.1.1",
    "babel-plugin-istanbul": "^8.0.0",
    "cross-env": "^10.1.0",
    "css-loader": "^6.11.0",
    "electron": "^42.4.0",
    "electron-installer-dmg": "^5.0.1",
    "eslint": "^10.4.1",
    "eslint-plugin-import-x": "^4.16.2",
    "fork-ts-checker-webpack-plugin": "^7.3.0",
    "node-loader": "^2.1.0",
    "npm-run-all": "^4.1.5",
    "nyc": "^18.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "style-loader": "^3.3.4",
    "ts-loader": "^9.5.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9",
    "webpack-dev-server": "^5.2.4"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "exceljs": "^4.4.0",
    "file-loader": "^6.2.0",
    "react-responsive": "^10.0.1"
  },
  "overrides": {
    "uuid": "^11.1.1",
    "tar": "^7.4.3",
    "tmp": "^0.2.3",
    "webpack-dev-server": "^5.2.4",
    "js-yaml": "^4.1.2"
  },
  "nyc": {
    "all": true,
    "sourceMap": true,
    "instrument": false,
    "include": [
      "src/renderer/**/*.{ts,tsx}"
    ],
    "exclude": [
      "node_modules/**",
      ".webpack/**",
      "e2e/**",
      "**/*.d.ts"
    ],
    "reporter": [
      "html",
      "lcov",
      "text"
    ]
  }
}
