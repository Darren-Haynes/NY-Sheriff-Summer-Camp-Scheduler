{
  "compilerOptions": {
    "target": "ES6",
    "allowJs": true,
    "module": "commonjs",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "./src",

    /* 1. KEEP THIS AT BUNDLER */
    "moduleResolution": "bundler",

    /* 2. COMPLETELY REMOVED "baseUrl": "." LINE FROM HERE */

    "resolveJsonModule": true,
    "strictNullChecks": true,
    "jsx": "react-jsx",

    /* 3. UPDATE PATHS TO USE RELATIVE PREFIX MAPPINGS */
    "paths": {
      "@src/*": ["./src/*"],
      "@assets/*": ["./assets/*"],
    },
  },
  "include": ["src/**/*", "assets/*", "src/renderer/**/*.d.ts"],
}
